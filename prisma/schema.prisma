generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SUPER_ADMIN
  OWNER
  HR
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
  PENDING_APPROVAL
}

enum EmploymentType {
  FRESHER
  EXPERIENCED
  INTERN
  CONTRACT
  PART_TIME
  FULL_TIME
}

enum OfferStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CompanyDocumentType {
  GST_CERTIFICATE
  PAN_CARD
  TAN_CERTIFICATE
  INCORPORATION_CERTIFICATE
  ADDRESS_PROOF
  BANK_PROOF
  PF_REGISTRATION
  ESI_REGISTRATION
  MSME_CERTIFICATE
  SHOP_LICENSE
  COMPANY_LOGO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WEEK_OFF
  HOLIDAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BGVStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
  FAILED
}

enum PolicyType {
  TERMS_AND_CONDITIONS
  PRIVACY_POLICY
  REFUND_POLICY
  COOKIE_POLICY
}

enum DegreeType {
  SSC
  INTERMEDIATE
  DIPLOMA
  BTECH
  MTECH
  MBA
  MCA
  BCOM
  MCOM
  BA
  MA
  PHD
  OTHER
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id       String @id @default(uuid())
  name     String
  email    String
  password String

  role   Role
  status Status @default(INVITED)

  profileLogo String? @db.LongText

  companyId String?
  company   Company? @relation("CompanyUsers", fields: [companyId], references: [id])

  isEmailVerified Boolean @default(false)

  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?

  employee Employee?
  hr       HR?

  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]

  createdCompanies Company[] @relation("CompanyCreator")

  companyInvites  CompanyInvite[]
  employeeInvites EmployeeInvite[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([email, companyId])
}

//////////////////////////////////////////////////////
// COMPANY
//////////////////////////////////////////////////////

model Company {
  id    String @id @default(uuid())
  name  String
  email String @unique

  ownerName  String?
  ownerEmail String?

  legalName String?

  phone   String?
  website String?

  domain String? @unique

  companyLogo String? @db.LongText

  industryTypeId String?
  industryType   IndustryType? @relation(fields: [industryTypeId], references: [id])

  companySize String?
  foundedYear Int?

  latitude  Float?
  longitude Float?

  status Status @default(INVITED)

  isEmailVerified    Boolean @default(false)
  isProfileCompleted Boolean @default(false)

  invitedAt    DateTime?
  activatedAt  DateTime?
  lastActiveAt DateTime?
  inactiveAt   DateTime?
  deletedAt    DateTime?

  createdById String
  createdBy   User   @relation("CompanyCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address        CompanyAddress?
  compliance     CompanyCompliance?
  payrollSetting CompanyPayrollSetting?
  hrSetting      CompanyHRSetting?
  systemSetting  CompanySystemSetting?

  directors CompanyDirector[]
  documents CompanyDocument[]

  users           User[]           @relation("CompanyUsers")
  employees       Employee[]
  departments     Department[]
  designations    Designation[]
  leaveTypes      LeaveType[]
  subscriptions   Subscription[]
  invites         CompanyInvite[]
  employeeInvites EmployeeInvite[]
  offerLetters    OfferLetter[]

  @@index([status])
  @@index([lastActiveAt])
}

//////////////////////////////////////////////////////
// COMPANY ADDRESS
//////////////////////////////////////////////////////

model CompanyAddress {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  addressLine1 String
  addressLine2 String?

  city    String
  state   String
  country String
  pincode String

  landmark String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY COMPLIANCE
//////////////////////////////////////////////////////

model CompanyCompliance {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  gstNumber String?
  panNumber String?
  tanNumber String?

  cinNumber  String?
  msmeNumber String?

  pfEnabled    Boolean @default(false)
  pfPercentage Float?

  esiEnabled Boolean @default(false)

  insuranceProvider String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY PAYROLL SETTINGS
//////////////////////////////////////////////////////

model CompanyPayrollSetting {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  currency String?

  salaryCycle String?

  payrollStartDay Int?
  payrollEndDay   Int?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY HR SETTINGS
//////////////////////////////////////////////////////

model CompanyHRSetting {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  workingHours String?
  workingDays  String?

  probationPeriod Int?
  noticePeriod    Int?

  companyPolicy String? @db.LongText

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY SYSTEM SETTINGS
//////////////////////////////////////////////////////

model CompanySystemSetting {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  timezone   String?
  dateFormat String?
  language   String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY DIRECTORS / CEO
//////////////////////////////////////////////////////

model CompanyDirector {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  fullName    String
  designation String?

  email String?
  phone String?

  aadhaarNumber String?
  panNumber     String?

  bankName      String?
  accountNumber String?
  ifscCode      String?

  address String?

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMPANY DOCUMENTS
//////////////////////////////////////////////////////

model CompanyDocument {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name CompanyDocumentType

  fileUrl String @db.LongText

  status DocumentStatus @default(PENDING)

  remarks String? @db.LongText

  uploadedAt DateTime  @default(now())
  verifiedAt DateTime?
}

//////////////////////////////////////////////////////
// COMPANY INVITE
//////////////////////////////////////////////////////

model CompanyInvite {
  id String @id @default(uuid())

  email String
  token String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  expiresAt    DateTime
  acceptedAt   DateTime?
  reminderSent Boolean   @default(false)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE / HR INVITES
//////////////////////////////////////////////////////

model EmployeeInvite {
  id String @id @default(uuid())

  email String
  token String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  role Role

  name String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  departmentId  String?
  designationId String?

  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// HR PROFILE
//////////////////////////////////////////////////////

model HR {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  permissions Json

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// OFFER LETTER
//////////////////////////////////////////////////////

model OfferLetter {
  id String @id @default(uuid())

  name          String?
  employeeEmail String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  role Role @default(EMPLOYEE)

  position String

  departmentId  String?
  designationId String?

  ctc          Float
  monthlyGross Float?
  variablePay  Float?
  joiningBonus Float?
  annualBonus  Float?

  joiningDate DateTime

  status OfferStatus @default(SENT)

  documentUrl String? @db.LongText

  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// EMPLOYEE
//////////////////////////////////////////////////////

model Employee {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employeeCode String @unique

  firstName  String?
  middleName String?
  lastName   String?

  profilePhoto String? @db.LongText
  signature    String? @db.LongText

  onboardingStep      Int     @default(1)
  onboardingCompleted Boolean @default(false)
  isDeclaredTrue      Boolean @default(false)

  probationPeriod String? @default("6 Months")
  noticePeriod    String? @default("90 Days")

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  designationId String
  designation   Designation @relation(fields: [designationId], references: [id])

  joiningDate DateTime

  employmentType EmploymentType

  workLocation String?

  managerId String?
  manager   Employee? @relation("Manager", fields: [managerId], references: [id])

  subordinates Employee[] @relation("Manager")

  status Status @default(INVITED)

  bgvStatus  BGVStatus @default(PENDING)
  bgvRemarks String?   @db.LongText

  personal          EmployeePersonal?
  experiences       EmployeeExperience[]
  educations        EmployeeEducation[]
  emergencyContacts EmployeeEmergencyContact[]

  skills EmployeeSkill[]

  bankDetails EmployeeBank?

  nominee EmployeeNominee?

  salaryStructure SalaryStructure?

  compliance EmployeeCompliance?

  joiningLetter JoiningLetter?
  offerLetter   OfferLetter?

  documents EmployeeDocument[]

  attendances Attendance[]
  leaves      Leave[]
  payrolls    Payroll[]

  deletedAt DateTime?
}

//////////////////////////////////////////////////////
// EMPLOYEE PERSONAL
//////////////////////////////////////////////////////

model EmployeePersonal {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  personalEmail String?

  phone          String?
  alternatePhone String?

  addressLine1 String?
  addressLine2 String?

  city    String?
  state   String?
  country String?
  pincode String?

  gender        String?
  dob           DateTime?
  maritalStatus String?
  bloodGroup    String?
  nationality   String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE EXPERIENCE
//////////////////////////////////////////////////////

model EmployeeExperience {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyName String
  role        String

  startDate DateTime
  endDate   DateTime?

  technologies     String?
  responsibilities String? @db.LongText

  totalYears Float?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE EDUCATION
//////////////////////////////////////////////////////

model EmployeeEducation {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  degree String

  specialization String?

  college    String?
  university String?

  percentage String?
  cgpa       String?

  startYear String?
  endYear   String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE EMERGENCY CONTACT
//////////////////////////////////////////////////////

model EmployeeEmergencyContact {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  contactPersonName String

  relationship String

  contactNumber    String
  alternateContact String?

  address String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE SKILLS
//////////////////////////////////////////////////////

model EmployeeSkill {
  id String @id @default(uuid())

  employeeId String @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  primarySkills   Json?
  secondarySkills Json?
  certifications  Json?
  languagesKnown  Json?

  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE BANK
//////////////////////////////////////////////////////

model EmployeeBank {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  bankName String?

  accountHolderName String?

  accountNumber String?

  ifscCode String?

  branchName String?

  upiId String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE NOMINEE
//////////////////////////////////////////////////////

model EmployeeNominee {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  nomineeName String

  relationship String

  dob DateTime?

  gender String?

  phone String?

  email String?

  aadhaarNumber String?
  panNumber     String?

  nomineePercentage Float?

  address String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE COMPLIANCE
//////////////////////////////////////////////////////

model EmployeeCompliance {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  pfNumber  String?
  esiNumber String?
  uanNumber String?

  insuranceId String?

  insuranceProvider String?
  policyNumber      String?

  coverageAmount Float?

  policyStartDate DateTime?
  policyEndDate   DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// EMPLOYEE DOCUMENTS
//////////////////////////////////////////////////////

model EmployeeDocument {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  name String

  fileUrl String @db.LongText

  status DocumentStatus @default(PENDING)

  remarks String? @db.LongText

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// JOINING LETTER
//////////////////////////////////////////////////////

model JoiningLetter {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  joiningDate DateTime

  documentUrl String? @db.LongText

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SALARY STRUCTURE
//////////////////////////////////////////////////////

model SalaryStructure {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  basic Float

  hra Float

  allowances Float

  bonus Float @default(0)

  pfEmployee  Float @default(0)
  esiEmployee Float @default(0)

  pfEmployer  Float @default(0)
  esiEmployer Float @default(0)

  deductions Float @default(0)

  netSalary Float @default(0)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DEPARTMENT
//////////////////////////////////////////////////////

model Department {
  id String @id @default(uuid())

  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DESIGNATION
//////////////////////////////////////////////////////

model Designation {
  id String @id @default(uuid())

  title String

  level Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// ATTENDANCE
//////////////////////////////////////////////////////

model Attendance {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date DateTime

  checkIn  DateTime?
  checkOut DateTime?

  status AttendanceStatus

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// LEAVE TYPES
//////////////////////////////////////////////////////

model LeaveType {
  id String @id @default(uuid())

  name String

  maxDays Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leaves Leave[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// LEAVES
//////////////////////////////////////////////////////

model Leave {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  fromDate DateTime
  toDate   DateTime

  reason String? @db.LongText

  status LeaveStatus @default(PENDING)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PAYROLL
//////////////////////////////////////////////////////

model Payroll {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  grossSalary Float

  deductions Float

  pfAmount Float

  esiAmount Float

  tdsAmount Float

  professionalTax Float

  bonus Float

  lopDays Float?

  netSalary Float

  payslipUrl String? @db.LongText

  status PayrollStatus @default(PENDING)

  month Int
  year  Int

  generatedAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////

model SubscriptionPlan {
  id String @id @default(uuid())

  name String @unique

  price Float

  duration Int

  features Json

  subscriptions Subscription[]

  createdAt DateTime @default(now())
}

model Subscription {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// AUDIT LOGS
//////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  action String
  module String

  metadata Json?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// INDUSTRY TYPES
//////////////////////////////////////////////////////

model IndustryType {
  id String @id @default(uuid())

  name String @unique

  departments  DepartmentTemplate[]
  designations DesignationTemplate[]

  companies Company[]

  salaryTemplate SalaryTemplate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// SALARY TEMPLATE
//////////////////////////////////////////////////////

model SalaryTemplate {
  id String @id @default(uuid())

  name String

  basicPercentage Float @default(50)

  hraPercentageOfBasic Float @default(40)

  pfPercentage Float @default(12)

  esiPercentage Float @default(0.75)

  employerPfPercentage Float @default(12)

  employerEsiPercentage Float @default(3.25)

  industryTypeId String       @unique
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// DEPARTMENT TEMPLATE
//////////////////////////////////////////////////////

model DepartmentTemplate {
  id String @id @default(uuid())

  name String

  industryTypeId String
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  designations DesignationTemplate[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DESIGNATION TEMPLATE
//////////////////////////////////////////////////////

model DesignationTemplate {
  id String @id @default(uuid())

  title String

  level Int @default(1)

  industryTypeId String
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  departmentId String?
  department   DepartmentTemplate? @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SYSTEM POLICIES
//////////////////////////////////////////////////////

model SystemPolicy {
  id String @id @default(uuid())

  type PolicyType @unique

  content String @db.LongText

  version String @default("1.0.0")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// PASSWORD RESET
//////////////////////////////////////////////////////

model PasswordResetToken {
  id String @id @default(uuid())

  token String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime

  createdAt DateTime @default(now())
}
