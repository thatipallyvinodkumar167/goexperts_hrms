generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////
// ENUMS
//////////////////////////

enum Role {
  SUPER_ADMIN
  OWNER
  HR
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
  PENDING_APPROVAL
}

enum EmploymentType {
  FRESHER
  EXPERIENCED
  INTERN
  CONTRACT
}

enum OfferStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CompanyDocumentType {
  GST_CERTIFICATE
  PAN_CARD
  TAN_CERTIFICATE
  INCORPORATION_CERTIFICATE
  ADDRESS_PROOF
  BANK_PROOF
  PF_REGISTRATION
  ESI_REGISTRATION
  COMPANY_LOGO
}

enum PolicyType {
  TERMS_AND_CONDITIONS
  PRIVACY_POLICY
  REFUND_POLICY
  COOKIE_POLICY
}

//////////////////////////
// USERS
//////////////////////////

model User {
  id       String @id @default(uuid())
  name     String
  email    String
  password String
  role     Role
  status   Status @default(INVITED)

  profileLogo String? @db.LongText

  companyId String?
  company   Company? @relation("CompanyUsers", fields: [companyId], references: [id])

  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?

  isEmailVerified Boolean @default(false)

  employee Employee?
  hr       HR?

  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  companyInvites      CompanyInvite[]
  employeeInvites     EmployeeInvite[]
  createdCompanies    Company[]            @relation("CompanyCreator")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  @@unique([email, companyId])
}

//////////////////////////
// COMPANY
//////////////////////////

model Company {
  id    String @id @default(uuid())
  name  String
  email String

  ownerName  String?
  ownerEmail String?

  domain   String? @unique
  location String?

  status Status @default(INVITED)

  companyLogo String?

  legalName      String?
  phone          String?
  website        String?
  industry       String?

  // Professional Details
  workingHours String? @default("9:00 AM - 6:00 PM")
  workingDays  String? @default("Monday - Friday")
  defaultProbationPeriod String? @default("6 Months")

  industryTypeId String?
  industryType   IndustryType? @relation(fields: [industryTypeId], references: [id])
  companySize    String?
  foundedYear    Int?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  pincode      String?

  gstNumber String?
  panNumber String?
  tanNumber String?

  probationPeriod Int?
  noticePeriod    Int?

  currency        String?
  salaryCycle     String?
  payrollStartDay Int?
  payrollEndDay   Int?

  pfEnabled         Boolean @default(false)
  pfPercentage      Float?
  esiEnabled        Boolean @default(false)
  insuranceProvider String?

  timezone   String?
  dateFormat String?
  language   String?

  invitedAt    DateTime?
  activatedAt  DateTime?
  lastActiveAt DateTime?
  inactiveAt   DateTime?
  deletedAt    DateTime?

  isEmailVerified    Boolean @default(false)
  isProfileCompleted Boolean @default(false)

  createdById String
  createdBy   User   @relation("CompanyCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  users           User[]            @relation("CompanyUsers")
  departments     Department[]
  designations    Designation[]
  leaveTypes      LeaveType[]
  subscriptions   Subscription[]
  invites         CompanyInvite[]
  employeeInvites EmployeeInvite[]
  employees       Employee[]
  documents       CompanyDocument[]
  offerLetters    OfferLetter[]

  @@index([status])
  @@index([lastActiveAt])
}

model CompanyDocument {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name    CompanyDocumentType
  fileUrl String
  status  String              @default("PENDING")

  uploadedAt DateTime  @default(now())
  verifiedAt DateTime?

  remarks String?

  @@index([companyId])
}

//////////////////////////
// COMPANY INVITE
//////////////////////////

model CompanyInvite {
  id    String @id @default(uuid())
  email String
  token String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  expiresAt    DateTime
  acceptedAt   DateTime?
  reminderSent Boolean   @default(false)

  createdAt DateTime @default(now())
}

//////////////////////////
// EMPLOYEE / HR INVITE
//////////////////////////

model EmployeeInvite {
  id String @id @default(uuid())

  email String
  token String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  role Role
  name String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  expiresAt  DateTime
  acceptedAt DateTime?

  departmentId String?
  designationId String?

  createdAt DateTime @default(now())
}

//////////////////////////
// OFFER LETTER
//////////////////////////

model OfferLetter {
  id String @id @default(uuid())

  name          String?
  employeeEmail String
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])

  salary      Float
  joiningDate DateTime
  position    String
  role        Role     @default(EMPLOYEE)

  departmentId String?
  designationId String?

  status OfferStatus @default(SENT)

  documentUrl String?

  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////
// EMPLOYEE
//////////////////////////

model Employee {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employeeCode String @unique

  firstName   String?
  lastName    String?
  middleName  String?
  profilePhoto String? @db.LongText

  onboardingStep      Int     @default(1)
  onboardingCompleted Boolean @default(false)

  // Contract Details
  probationPeriod     String? @default("6 Months")
  noticePeriod        String? @default("90 Days")

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  designationId String
  designation   Designation @relation(fields: [designationId], references: [id])

  joiningDate    DateTime
  employmentType EmploymentType

  workLocation String?

  managerId    String?
  manager      Employee?  @relation("Manager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("Manager")

  status Status @default(INVITED)

  bgvStatus  String  @default("PENDING") // PENDING, APPROVED, REJECTED
  bgvRemarks String? @db.LongText

  personal          EmployeePersonal?
  experience        EmployeeExperience[]
  education         EmployeeEducation[]
  emergencyContacts EmployeeEmergencyContact[]
  skills            EmployeeSkill?
  bankDetails       EmployeeBank?
  nominee           EmployeeNominee?

  salary     SalaryStructure?
  compliance EmployeeCompliance?

  joiningLetter JoiningLetter?
  offerLetter   OfferLetter?

  documents EmployeeDocument[]

  attendances Attendance[]
  leaves      Leave[]
  payrolls    Payroll[]

  deletedAt DateTime?
}

//////////////////////////
// HR PROFILE
//////////////////////////

model HR {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  permissions Json
}

//////////////////////////
// SALARY STRUCTURE
//////////////////////////

model SalaryStructure {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  basic      Float
  hra        Float
  allowances Float
  bonus      Float @default(0)
  
  // Statutory Components (Employee)
  pfEmployee   Float @default(0)
  esiEmployee  Float @default(0)

  // Statutory Components (Employer - Cost to Company)
  pfEmployer   Float @default(0)
  esiEmployer  Float @default(0)

  deductions Float @default(0)
  netSalary  Float @default(0)

  createdAt DateTime @default(now())
}

//////////////////////////
// COMPLIANCE
//////////////////////////

model EmployeeCompliance {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  pfNumber    String?
  esiNumber   String?
  uanNumber   String?
  insuranceId String?
  
  insuranceProvider String?
  policyNumber      String?
  coverageAmount    Float?
  policyStartDate   DateTime?
  policyEndDate     DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////
// DOCUMENTS
//////////////////////////

model EmployeeDocument {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  name    String
  fileUrl String

  status  String  @default("PENDING") // PENDING, APPROVED, REJECTED
  remarks String? @db.LongText

  createdAt DateTime @default(now())
}

//////////////////////////
// JOINING LETTER
//////////////////////////

model JoiningLetter {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  joiningDate DateTime
  documentUrl String?

  createdAt DateTime @default(now())
}

//////////////////////////
// PERSONAL
//////////////////////////

model EmployeePersonal {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  personalEmail    String?
  phone            String?
  alternatePhone   String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  country          String?
  pincode          String?
  gender           String?
  dob              DateTime?
  maritalStatus    String?
  bloodGroup       String?
  nationality      String?
}

//////////////////////////
// EMERGENCY CONTACT
//////////////////////////

model EmployeeEmergencyContact {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  contactPersonName String
  relationship      String
  contactNumber     String
  alternateContact  String?
  address           String?
}

//////////////////////////
// EDUCATION
//////////////////////////

model EmployeeEducation {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  degree         String
  specialization String?
  college        String?
  university     String?
  percentage     String?
  cgpa           String?
  startYear      String?
  endYear        String?
}

//////////////////////////
// SKILLS & CERTIFICATIONS
//////////////////////////

model EmployeeSkill {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  primarySkills   Json?
  secondarySkills Json?
  certifications  Json?
  languagesKnown  Json?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
}

//////////////////////////
// BANK DETAILS
//////////////////////////

model EmployeeBank {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  bankName          String?
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?
  branchName        String?
  upiId             String?
}

//////////////////////////
// NOMINEE DETAILS
//////////////////////////

model EmployeeNominee {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])

  nomineeName       String
  relationship      String
  dob               DateTime?
  gender            String?
  phone             String?
  email             String?
  aadhaarNumber     String?
  panNumber         String?
  nomineePercentage Float?
  address           String?
}

//////////////////////////
// EXPERIENCE
//////////////////////////

model EmployeeExperience {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyName String
  role        String
  startDate   DateTime
  endDate     DateTime?

  technologies     String?
  responsibilities String? @db.LongText

  totalYears Float?
}

//////////////////////////
// COMPANY STRUCTURE
//////////////////////////

model Department {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]
}

model Designation {
  id    String @id @default(uuid())
  title String
  level Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]
}

//////////////////////////
// ATTENDANCE
//////////////////////////

model Attendance {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date     DateTime
  checkIn  DateTime?
  checkOut DateTime?
  status   String
}

//////////////////////////
// LEAVE
//////////////////////////

model LeaveType {
  id      String @id @default(uuid())
  name    String
  maxDays Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leaves Leave[]
}

model Leave {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  fromDate DateTime
  toDate   DateTime
  status   String
}

//////////////////////////
// PAYROLL
//////////////////////////

model Payroll {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  netSalary Float

  month Int
  year  Int
}

//////////////////////////
// SUBSCRIPTION
//////////////////////////

model SubscriptionPlan {
  id       String @id @default(uuid())
  name     String
  price    Float
  duration Int
  features Json

  subscriptions Subscription[]
}

model Subscription {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  startDate DateTime
  endDate   DateTime
}

//////////////////////////
// AUDIT
//////////////////////////

model AuditLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  action   String
  module   String
  metadata Json?

  createdAt DateTime @default(now())
}

//////////////////////////
// MASTER TEMPLATES (GLOBAL)
//////////////////////////

model IndustryType {
  id   String @id @default(uuid())
  name String @unique

  departments  DepartmentTemplate[]
  designations DesignationTemplate[]
  companies    Company[]
  salaryTemplate SalaryTemplate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalaryTemplate {
  id    String @id @default(uuid())
  name  String 
  
  basicPercentage      Float @default(50)
  hraPercentageOfBasic Float @default(40) // HRA as % of Basic
  
  pfPercentage         Float @default(12)   // % of Basic
  esiPercentage        Float @default(0.75) // % of Gross
  employerPfPercentage Float @default(12)   // % of Basic
  employerEsiPercentage Float @default(3.25) // % of Gross
  
  industryTypeId String @unique
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DepartmentTemplate {
  id   String @id @default(uuid())
  name String

  industryTypeId String
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  createdAt DateTime @default(now())
}

model DesignationTemplate {
  id    String @id @default(uuid())
  title String
  level Int    @default(1)

  industryTypeId String
  industryType   IndustryType @relation(fields: [industryTypeId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////////
// SYSTEM POLICIES
//////////////////////////

model SystemPolicy {
  id       String     @id @default(uuid())
  type     PolicyType @unique
  content  String     @db.LongText
  version  String     @default("1.0.0")
  isActive Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////
// PASSWORD RESET
//////////////////////////

model PasswordResetToken {
  id     String @id @default(uuid())
  token  String
  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}
