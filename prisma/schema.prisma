generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////
// ENUMS
//////////////////////////

enum Role {
  SUPER_ADMIN
  OWNER
  HR
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

enum EmploymentType {
  FRESHER
  EXPERIENCED
  INTERN
  CONTRACT
}

enum EmployeeStatus {
  ACTIVE
  ONBOARDING
  PROBATION
  RESIGNED
  TERMINATED
}

//////////////////////////
// USERS
//////////////////////////

model User {
  id          String   @id @default(uuid())
  name        String
  email       String
  password    String
  role        Role
  status      Status   @default(ACTIVE)
  profileLogo String?

  companyId   String?
  company     Company? @relation("CompanyUsers", fields: [companyId], references: [id])

  // OWNER RELATION
  ownedCompany Company? @relation("CompanyOwner")

  createdCompanies Company[] @relation("CompanyCreator")

  createdAt   DateTime @default(now())
  lastLoginAt DateTime?

  employee    Employee?
  hr          HR?

  auditLogs   AuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@unique([email, companyId])
}

//////////////////////////
// COMPANY
//////////////////////////

model Company {
  id          String   @id @default(uuid())
  name        String
  email       String

  domain      String?  @unique
  location    String?

  status      Status   @default(ACTIVE)

  lastActiveAt DateTime?
  inactiveAt   DateTime?
  deletedAt    DateTime?

  companyLogo String?

  // OWNER LINK
  ownerId     String?   @unique
  owner       User?     @relation("CompanyOwner", fields: [ownerId], references: [id])

  createdById String
  createdBy   User     @relation("CompanyCreator", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]   @relation("CompanyUsers")

  departments Department[]
  designations Designation[]
  leaveTypes  LeaveType[]
  subscriptions Subscription[]

  @@index([status])
  @@index([lastActiveAt])
}

//////////////////////////
// HR PROFILE
//////////////////////////

model HR {
  id        String @id @default(uuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  // granular permissions
  permissions Json
}

//////////////////////////
// EMPLOYEE
//////////////////////////

model Employee {
  id            String @id @default(uuid())

  userId        String @unique
  user          User   @relation(fields: [userId], references: [id])

  employeeCode  String @unique

  // JOB INFO
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])

  designationId String
  designation   Designation @relation(fields: [designationId], references: [id])

  joiningDate   DateTime
  employmentType EmploymentType

  employeeStatus EmployeeStatus @default(ONBOARDING)

  workLocation  String?
  salary        Float

  // reporting hierarchy
  managerId     String?
  manager       Employee? @relation("Manager", fields: [managerId], references: [id])
  subordinates  Employee[] @relation("Manager")

  // HRMS STRUCTURE
  personal      EmployeePersonal?
  experience    EmployeeExperience[]

  joiningLetter JoiningLetter?

  // lifecycle
  relievedAt    DateTime?
  reasonOfExit  String?

  attendances   Attendance[]
  leaves        Leave[]
  payrolls      Payroll[]

  @@index([employeeCode])
}

//////////////////////////
// JOINING LETTER
//////////////////////////

model JoiningLetter {
  id          String @id @default(uuid())

  employeeId  String @unique
  employee    Employee @relation(fields: [employeeId], references: [id])

  joiningDate DateTime
  documentUrl String?

  createdAt   DateTime @default(now())
}

//////////////////////////
// PERSONAL DETAILS
//////////////////////////

model EmployeePersonal {
  id                String @id @default(uuid())

  employeeId        String @unique
  employee          Employee @relation(fields: [employeeId], references: [id])

  phone             String?
  address           String?
  gender            String?
  dob               DateTime?

  emergencyContact  String?

  bloodGroup        String?
  maritalStatus     String?
}

//////////////////////////
// EXPERIENCE
//////////////////////////

model EmployeeExperience {
  id           String @id @default(uuid())

  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])

  companyName  String
  role         String
  startDate    DateTime
  endDate      DateTime?

  totalYears   Float?
}

//////////////////////////
// COMPANY STRUCTURE
//////////////////////////

model Department {
  id        String @id @default(uuid())
  name      String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]
}

model Designation {
  id        String @id @default(uuid())
  title     String
  level     Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]
}

//////////////////////////
// ATTENDANCE
//////////////////////////

model Attendance {
  id         String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?

  status     String

  @@index([date])
}

//////////////////////////
// LEAVE
//////////////////////////

model LeaveType {
  id        String @id @default(uuid())
  name      String
  maxDays   Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leaves    Leave[]
}

model Leave {
  id          String @id @default(uuid())

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  fromDate    DateTime
  toDate      DateTime

  status      String
}

//////////////////////////
// PAYROLL
//////////////////////////

model Payroll {
  id          String @id @default(uuid())

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  basicSalary Float
  deductions  Float
  bonus       Float
  netSalary   Float

  month       Int
  year        Int
}

//////////////////////////
// SUBSCRIPTION
//////////////////////////

model SubscriptionPlan {
  id        String @id @default(uuid())
  name      String
  price     Float
  duration  Int
  features  Json

  subscriptions Subscription[]
}

model Subscription {
  id          String @id @default(uuid())

  companyId   String
  company     Company @relation(fields: [companyId], references: [id])

  planId      String
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])

  startDate   DateTime
  endDate     DateTime
}

//////////////////////////
// AUDIT
//////////////////////////

model AuditLog {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  action    String
  module    String

  createdAt DateTime @default(now())
}

//////////////////////////
// PASSWORD RESET
//////////////////////////

model PasswordResetToken {
  id        String   @id @default(uuid())

  token     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}
